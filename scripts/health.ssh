#!/bin/bash
echo "===== SYSTEM HEALTH CHECK ====="
echo "Date: $(date)"
echo
echo "Hostname:"
hostname
echo
echo "Uptime:"
uptime
echo
echo "Disk usage:"
df -h
echo
echo "Memory usage:"
free -h
echo
echo "Running nginx process:"
ps aux | grep nginx | grep -v grep
echo
echo "Listening ports:"
ss -tulpn
echo "===== END ====="